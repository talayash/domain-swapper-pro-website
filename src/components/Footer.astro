---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800/50 py-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <img src="/icons/icon.png" alt="Domain Swapper Pro" class="w-5 h-5" />
        <span class="text-slate-400 text-sm">Domain Swapper Pro</span>
      </div>
      <div class="flex items-center gap-6 text-sm text-slate-500">
        <a href="https://github.com/talayash/domain-swapper-pro" target="_blank" rel="noopener noreferrer" class="hover:text-slate-300 transition-colors">GitHub</a>
        <a href="https://chromewebstore.google.com/detail/domain-swapper-pro/lkjaaifkmcomiaakacfgfggnpckamklp" target="_blank" rel="noopener noreferrer" class="hover:text-slate-300 transition-colors">Chrome Web Store</a>
      </div>
      <p class="text-slate-600 text-sm">&copy; {year}</p>
    </div>
  </div>
</footer>
